generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Game {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String   @default("")
  category    String   @default("Action")
  thumbnail   String   @default("/placeholder-game.png")
  gameUrl     String   @map("game_url")
  developer   String   @default("")
  rating      Float    @default(4.0)
  ratingCount Int      @default(0) @map("rating_count")
  plays       Int      @default(0)
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  favorites   Favorite[]
  ratings     GameRating[]
  progresses  GameProgress[]
  bugReports  GameBugReport[]

  @@index([category, active])
  @@map("games")
}

model Config {
  key   String @id
  value Json

  @@map("config")
}

model User {
  id        String   @id
  email     String?  @unique
  name      String?
  image     String?
  role      String   @default("user")
  createdAt DateTime @default(now()) @map("created_at")
  favorites Favorite[]
  ratings   GameRating[]
  progress  GameProgress[]
  bugReports GameBugReport[]

  @@map("users")
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  gameId    Int      @map("game_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
  @@map("favorites")
}

model GameRating {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  gameId    Int      @map("game_id")
  rating    Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@map("game_ratings")
}

model GameProgress {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  gameId      Int      @map("game_id")
  elapsedSec  Int      @default(0) @map("elapsed_sec")
  progressPct Int?     @map("progress_pct")
  stateJson   Json?    @map("state_json")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@map("game_progress")
}

model GameBugReport {
  id         Int      @id @default(autoincrement())
  gameId      Int      @map("game_id")
  userId      String?  @map("user_id")
  email       String?
  message     String
  pageUrl     String?  @map("page_url")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([gameId])
  @@index([userId])
  @@map("game_bug_reports")
}
